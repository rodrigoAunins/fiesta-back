# Render sets PORT automatically for Web Services.
NODE_ENV=production

# Prefer the Render Postgres Internal Database URL.
DATABASE_URL=

# Alternative DB variables if you are not using DATABASE_URL.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false

# Keep true for first deploy if you want TypeORM to create/update tables.
# Set to false later if you move to migrations.
TYPEORM_SYNCHRONIZE=true

JWT_SECRET=
FRONTEND_URL=
CORS_ORIGIN=
BACKEND_URL=
API_BASE_URL=

SUPERADMIN_EMAILS=

# Google OAuth, only required if Google login is enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Mercado Pago, only required for payment flows.
MP_ACCESS_TOKEN=
MP_APP_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=
PLATFORM_FEE_RATE=0.1

RAFFLE_RESERVATION_MINUTES=10
DEFAULT_OG_IMAGE_URL=
